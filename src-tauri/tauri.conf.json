{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cutest-disk-tree",
  "version": "0.1.1",
  "identifier": "com.cutest.disk-tree",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cutest Disk Tree",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "longDescription": "Cross-platform disk usage and duplicate-file analyzer.",
    "shortDescription": "Disk usage analyzer",
    "category": "Utility"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Odin94/cutest-disk-tree/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NjcwQTkwMjQ0NTI5NEEKUldSS0tVVWtrQXBuK1lITlQ2SXhjM3lPMHdsVitxaVJSWlU2MHNLSUFzeldxV0pmdytpazJLQW0K"
    }
  }
}